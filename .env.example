# =============================================================================
# Frontend (Vite / Vercel) — Main site + Growth + Network
# Copy to .env and fill in real values: cp .env.example .env
# =============================================================================

VITE_SUPABASE_URL=https://kong-production-3917.up.railway.app
# Same anon key as master-os NEXT_PUBLIC_SUPABASE_ANON_KEY
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# VITE_PARTNER_PORTAL_GET_STARTED_URL=http://localhost:3001/get-started

# Optional — main site B2C booking (Google Maps autocomplete)
# VITE_GOOGLE_API_KEY=

# =============================================================================
# Supabase Edge Function secrets — set in Supabase Dashboard or CLI, NOT here.
# See GROWTH-SETUP.md and: npm run setup:secrets:print
# =============================================================================

# Stripe (test: sk_test_... / whsec_test_... | live: sk_live_... / whsec_...)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Growth checkout (£379 one-off — amount loaded from STRIPE_GROWTH_PRICE_ID)
STRIPE_GROWTH_PRICE_ID=price_...

# Network checkout (subscriptions)
# STRIPE_NETWORK_MONTHLY_PRICE_ID=price_...
# STRIPE_NETWORK_ANNUAL_PRICE_ID=price_...

# Google Calendar (Growth onboarding + main-site "Schedule a meeting")
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GROWTH_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# GROWTH_NOTIFY_EMAIL=victor@getfixfy.com

# Transactional email (Growth booking confirmations)
# RESEND_API_KEY=re_...

# Network invite links (?access=TOKEN skips payment)
# NETWORK_ACCESS_TOKENS=token1,token2

# Use /api/growth in dev/Vercel (Railway edge /functions/v1 returns 401). Optional override:
# VITE_GROWTH_API_URL=/api/growth
